{
  "expo": {
    "name": "이게뭐약",
    "slug": "whatispill",
    "scheme": "whatispill",
    "owner": "mustbemadness",
    "version": "3.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/icon.png",
    "newArchEnabled": true,
    "platforms": ["ios", "android"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mbm.whatispill",
      "icon": {
        "light": "./assets/icons/ios-icon.png",
        "dark": "./assets/icons/ios-icon.png",
        "tinted": "./assets/icons/ios-icon.png"
      },
      "infoPlist": {
        "NSCameraUsageDescription": "$(PRODUCT_NAME)에서 알약을 촬영하여 검색하기 위해 카메라 권한이 필요합니다",
        "NSPhotoLibraryUsageDescription": "$(PRODUCT_NAME)에서 알약 검색에 필요한 이미지를 가져오기 위해 사진 권한이 필요합니다",
        "LSApplicationQueriesSchemes": ["mailto"]
      }
    },
    "android": {
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBh9jPoKXOelpLI0fvoCcvY_Cmz2cEfayY"
        }
      },
      "splash": {
        "image": "./assets/icons/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#ffffff"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/adaptive-icon.png",
        "monochromeImage": "./assets/icons/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.mbm.whatispill",
      "versionCode": 21,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED"
      ]
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "imageWidth": 200
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "useLegacyPackaging": true,
            "enableProguardInReleaseBuilds": true,
            "extraProguardRules": "-keep class io.realm.** { *; }\n-keep class io.realm.react.** { *; }\n-dontwarn java.beans.**\n-dontwarn javax.xml.bind.**"
          }
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermission": "$(PRODUCT_NAME)에서 알약을 촬영하기 위해 카메라 권한이 필요합니다"
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "$(PRODUCT_NAME)에서 알약 촬영시 초점 이동을 위해 모션 권한이 필요합니다"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/NotoSansKR-Black.ttf",
            "./assets/fonts/NotoSansKR-Bold.ttf",
            "./assets/fonts/NotoSansKR-ExtraBold.ttf",
            "./assets/fonts/NotoSansKR-Light.ttf",
            "./assets/fonts/NotoSansKR-Medium.ttf",
            "./assets/fonts/NotoSansKR-Regular.ttf",
            "./assets/fonts/NotoSansKR-SemiBold.ttf"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "$(PRODUCT_NAME)에서 알약 검색에 필요한 이미지를 가져오기 위해 사진 권한이 필요합니다",
          "cameraPermission": "$(PRODUCT_NAME)에서 알약을 촬영하여 검색하기 위해 카메라 권한이 필요합니다"
        }
      ],
      ["expo-localization"],
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "$(PRODUCT_NAME)에서 주변 약국을 찾기 위해 위치 권한이 필요합니다"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "8120ae66-d8a3-4e4a-885e-a76c3477b881"
      }
    }
  }
}
